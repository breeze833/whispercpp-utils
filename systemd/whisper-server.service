[Unit]
Description=Local Whisper.cpp Server
After=network.target

[Service]
WorkingDirectory=%h/src/whisper.cpp
ExecStart=./build/bin/whisper-server -m ./models/ggml-large-v3-turbo-q8_0.bin --vad -vm ./models/ggml-silero-v6.2.0.bin -vt 0.3 -l zh --prompt "輸出台灣繁體中文，包含正確標點符號。例如：逗號、頓號、句號。" --carry-initial-prompt
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
